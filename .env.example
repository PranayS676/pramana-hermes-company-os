# Dashboard state
HERMES_COMPANY_OS_DB=./data/company_os.db
COMPANY_TIMEZONE=America/New_York
HERMES_TIMEOUT_SECONDS=300

# Real Hermes profile commands.
# These defaults assume Hermes created command aliases for each profile.
HERMES_COMMAND_CHIEF_OF_STAFF=chief-of-staff
HERMES_COMMAND_PRODUCT_MANAGER=product-manager
HERMES_COMMAND_RESEARCH_AGENT=research-agent
HERMES_COMMAND_ENGINEERING_MANAGER=engineering-manager
HERMES_COMMAND_MARKETING_AGENT=marketing-agent
HERMES_COMMAND_QA_CRITIC=qa-critic

# These are channel names used in prompts and UI labels, not secrets.
SLACK_FOUNDER_COMMAND=#founder-command
SLACK_STANDUP=#agent-standup
SLACK_ALERTS=#alerts
TELEGRAM_URGENT_LABEL=Founder Telegram urgent channel

